{
  "name": "passreserve",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:copy": "node scripts/ui-copy-audit.mjs",
    "test:smoke": "node scripts/smoke-check.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "postinstall": "prisma generate",
    "verify": "npm run lint && npm run test && npm run test:copy && npm run db:generate && npm run build && npm run test:smoke"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@radix-ui/react-slot": "^1.2.3",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "iron-session": "8.0.4",
    "lucide-react": "^0.549.0",
    "next": "16.2.2",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "stripe": "^22.0.0",
    "tailwind-merge": "^3.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.15",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "prisma": "6.19.3",
    "tailwindcss": "^4.1.15",
    "tw-animate-css": "^1.3.8",
    "vitest": "^4.1.2"
  }
}
